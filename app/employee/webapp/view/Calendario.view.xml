<mvc:View
  controllerName="sysko.ferie.employee.controller.Calendario"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">

  <Page title="Calendario Ferie Colleghi" showNavButton="true" navButtonPress=".onNavBack"
        class="sapUiNoContentPadding">

    <content>

      <!-- Navigazione mese -->
      <HBox justifyContent="SpaceBetween" alignItems="Center"
            class="sapUiSmallMarginTopBottom sapUiSmallMarginBeginEnd">
        <Button icon="sap-icon://slim-arrow-left"  tooltip="Mese precedente" press=".onPrevMonth"/>
        <Title id="calTitle" text="" level="H4"/>
        <Button icon="sap-icon://slim-arrow-right" tooltip="Mese successivo" press=".onNextMonth"/>
      </HBox>

      <!-- Legenda -->
      <HBox class="sapUiTinyMarginBottom sapUiSmallMarginBeginEnd" alignItems="Center" wrap="Wrap">
        <HBox alignItems="Center" class="sapUiTinyMarginEnd">
          <core:HTML content="&lt;span style='display:inline-block;width:14px;height:14px;background:#a5d6a7;border-radius:3px;margin-right:4px'&gt;&lt;/span&gt;"/>
          <Text text="Assente (approvato)"/>
        </HBox>
        <HBox alignItems="Center" class="sapUiTinyMarginEnd">
          <core:HTML content="&lt;span style='display:inline-block;width:14px;height:14px;background:#eeeeee;border-radius:3px;margin-right:4px'&gt;&lt;/span&gt;"/>
          <Text text="Weekend"/>
        </HBox>
        <HBox alignItems="Center" class="sapUiTinyMarginEnd">
          <core:HTML content="&lt;span style='display:inline-block;width:14px;height:14px;background:#ffebee;border-radius:3px;margin-right:4px'&gt;&lt;/span&gt;"/>
          <Text text="Festivo"/>
        </HBox>
      </HBox>

      <!-- Matrice assenze -->
      <core:HTML id="calHtml" content="&lt;div&gt;Caricamento...&lt;/div&gt;"
                 class="sk-grid"/>

    </content>
  </Page>

</mvc:View>
