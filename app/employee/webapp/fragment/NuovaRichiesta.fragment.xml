<core:FragmentDefinition
  xmlns:core="sap.ui.core"
  xmlns="sap.m"
  xmlns:l="sap.ui.layout.form">

  <Dialog title="Nuova Richiesta di Assenza" contentWidth="420px" draggable="true">
    <content>
      <l:SimpleForm
        editable="true" layout="ResponsiveGridLayout"
        labelSpanXL="4" labelSpanL="4" labelSpanM="4"
        columnsXL="1" columnsL="1" columnsM="1"
        class="sapUiSmallMarginTop">
        <l:content>

          <Label text="Tipo Assenza" required="true"/>
          <Select id="selTipo" width="100%" forceSelection="false"
                  selectedKey="FERIE" change=".onTipoChange">
            <items>
              <core:Item key="FERIE"          text="Ferie"/>
              <core:Item key="PERMESSO"       text="Permesso"/>
              <core:Item key="ROL"            text="ROL"/>
              <core:Item key="MALATTIA"       text="Malattia"/>
              <core:Item key="LUTTO"          text="Lutto"/>
              <core:Item key="MATRIMONIO"     text="Matrimonio"/>
              <core:Item key="FERIE_FITTIZIE" text="Ferie Fittizie"/>
            </items>
          </Select>

          <Label text="Bene Ceduto" required="true" visible="{dialog>/isFittizio}"/>
          <TextArea id="taBeneCeduto" rows="2" width="100%"
                    placeholder="Es. Auto aziendale Targa AB123"
                    visible="{dialog>/isFittizio}"/>

          <Label text="Data Inizio" required="true"/>
          <DatePicker id="dpInizio"
            valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy"
            width="100%" placeholder="gg/mm/aaaa"/>

          <Label text="Data Fine" required="true"/>
          <DatePicker id="dpFine"
            valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy"
            width="100%" placeholder="gg/mm/aaaa"/>

          <Label text="Note"/>
          <TextArea id="taNota" rows="3" width="100%"
                    placeholder="Motivazione (opzionale)"/>

        </l:content>
      </l:SimpleForm>
    </content>

    <beginButton>
      <Button text="Invia Richiesta" type="Emphasized"
              icon="sap-icon://paper-plane" press=".onSubmitRichiesta"/>
    </beginButton>
    <endButton>
      <Button text="Chiudi" press=".onCancelDialog"/>
    </endButton>
  </Dialog>

</core:FragmentDefinition>
