<mvc:View
  controllerName="sysko.ferie.manager.controller.Matrice"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">

  <Page showHeader="false" backgroundDesign="Transparent" class="sapUiNoContentPadding">
    <content>

      <!-- ── Page header ── -->
      <Toolbar class="sk-page-header">
        <Title text="Matrice Ferie Team" level="H1"/>
        <ToolbarSpacer/>
        <Button icon="sap-icon://nav-back" tooltip="Mese precedente" press=".onPrevMonth"/>
        <Title id="matTitle" text="" class="sapUiSmallMarginBeginEnd"/>
        <Button icon="sap-icon://slim-arrow-right" tooltip="Mese successivo" press=".onNextMonth"/>
        <Button text="Oggi" press=".onToday" class="sapUiSmallMarginBegin"/>
        <Button text="Esporta CSV" icon="sap-icon://download" press=".onExportCsv"
                class="sapUiSmallMarginBegin"/>
      </Toolbar>

      <!-- ── Legenda ── -->
      <HBox class="sk-legend">
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#43a047'&gt;&lt;/span&gt;"/>
          <Text text="Ferie approvate"/>
        </HBox>
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#8e24aa'&gt;&lt;/span&gt;"/>
          <Text text="Ferie Fittizie"/>
        </HBox>
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#ffa726'&gt;&lt;/span&gt;"/>
          <Text text="In attesa"/>
        </HBox>
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#cfd8dc'&gt;&lt;/span&gt;"/>
          <Text text="Weekend / Festivo"/>
        </HBox>
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#fff9c4;border:1px solid #f9a825'&gt;&lt;/span&gt;"/>
          <Text text="Tot. mensile (Σ)"/>
        </HBox>
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#7986cb'&gt;&lt;/span&gt;"/>
          <Text text="Totale team"/>
        </HBox>
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#f1f8e9;border:1px solid #aed581'&gt;&lt;/span&gt;"/>
          <Text text="Interno"/>
        </HBox>
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#c8e6c9;border:1px solid #66bb6a'&gt;&lt;/span&gt;"/>
          <Text text="Esterno"/>
        </HBox>
      </HBox>

      <!-- ── Matrice HTML ── -->
      <core:HTML id="matHtml" content="&lt;div&gt;Caricamento...&lt;/div&gt;"
                 class="sk-grid"/>

    </content>
  </Page>

</mvc:View>
