<mvc:View
  controllerName="sysko.ferie.manager.controller.Sovrapposizioni"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">

  <Page showHeader="false" backgroundDesign="Transparent">
    <content>

      <!-- ── Page header ── -->
      <Toolbar class="sk-page-header">
        <Title text="Sovrapposizioni Ferie" level="H1"/>
        <ToolbarSpacer/>
        <Button icon="sap-icon://nav-back" tooltip="Mese precedente" press=".onPrevMonth"/>
        <Title id="sovTitle" text="" class="sapUiSmallMarginBeginEnd"/>
        <Button icon="sap-icon://slim-arrow-right" tooltip="Mese successivo" press=".onNextMonth"/>
        <Button text="Oggi" press=".onToday" class="sapUiSmallMarginBegin"/>
      </Toolbar>

      <!-- ── Legenda ── -->
      <HBox class="sk-legend">
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#2e7d32;border-radius:50%'&gt;&lt;/span&gt;"/>
          <Text text="Approvata"/>
        </HBox>
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#e65100;border-radius:50%;border:2px solid #e65100;box-sizing:border-box'&gt;&lt;/span&gt;"/>
          <Text text="In attesa"/>
        </HBox>
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#fff9c4;border:1px solid #ffa726'&gt;&lt;/span&gt;"/>
          <Text text="2 persone"/>
        </HBox>
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#ffe0b2;border:1px solid #ef6c00'&gt;&lt;/span&gt;"/>
          <Text text="3 persone"/>
        </HBox>
        <HBox alignItems="Center" class="sk-legend-item">
          <core:HTML content="&lt;span class='sk-legend-dot' style='background:#ffcdd2;border:1px solid #e53935'&gt;&lt;/span&gt;"/>
          <Text text="4+ persone (critico)"/>
        </HBox>
      </HBox>

      <!-- ── Tabella sovrapposizioni ── -->
      <core:HTML id="sovHtml" content="&lt;div&gt;Caricamento...&lt;/div&gt;"
                 class="sapUiResponsiveMargin sk-grid"/>

    </content>
  </Page>

</mvc:View>
