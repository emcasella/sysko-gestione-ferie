{
  "name": "sysko-gestione-ferie",
  "version": "1.0.0",
  "description": "SYSKO - Gestione Ferie e Permessi (SAP CAP)",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@sap/cds": "^7",
    "@sap/cds-hana": "^2",
    "@sap/xsenv": "^3",
    "@sap/xssec": "^3",
    "express": "^4",
    "nodemailer": "^6",
    "passport": "^0.6",
    "@sap-cloud-sdk/mail-client": "^3"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^1",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@sap/cds-dk": "^7",
    "docx": "^9.6.1"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "[production]": {
          "kind": "hana-cloud",
          "pool": {
            "max": 100,
            "min": 0
          }
        }
      },
      "auth": {
        "kind": "basic",
        "[production]": {
          "kind": "xsuaa"
        }
      }
    },
    "odata": {
      "version": "v4"
    },
    "features": {
      "fetch_csrf": true
    },
    "i18n": {
      "default_language": "it"
    }
  }
}